# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted (e.g., https://sipades-desa.id).
APP_URL="http://localhost:3000"

# FONNTE_TOKEN: WhatsApp Gateway API Key from fonnte.com.
FONNTE_TOKEN="YOUR_FONNTE_GATEWAY_TOKEN"

# DATABASE ENVIRONMENT VARIABLES (MySQL)
MYSQL_HOST="127.0.0.1"
MYSQL_PORT="3306"
MYSQL_USER="root"
MYSQL_PASSWORD=""
MYSQL_DB_NAME="sipades_db"

