### ----------------------------------------------------------------------
### .htaccess - KONFIGURASI DEPLOYMENT PHP & MYSQL (CYBERPANEL & OPENLITESPEED)
### Aplikasi: SIPADES SMART (Desa Rarang Selatan) - Pure PHP & MySQL Edition
### ----------------------------------------------------------------------

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1. Alihkan koneksi HTTP ke HTTPS secara otomatis (Menggunakan SSL Aktif)
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 2. Rute Pencocokan Folder (Dual-Setup Compatibility)
    # JIKA seluruh file PHP dibiarkan di dalam subfolder "/php" pada root hosting:
    # Mengarahkan pengunjung dari halaman utama (/) langsung ke "/php/index.php" secara visual.
    RewriteCond %{REQUEST_URI} ^/$
    RewriteCond %{DOCUMENT_ROOT}/php/index.php -f
    RewriteRule ^$ /php/index.php [L,R=301]

    # 3. Rute "Pretty URLs" (Opsional / Estetika)
    # Memungkinkan operator membuka halaman seperti 'domain.com/dashboard' tanpa mengetik '.php'.
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.php -f
    RewriteRule ^([^/]+)$ $1.php [L]
</IfModule>

# ========================================================================
# PERLINDUNGAN KEAMANAN DIREKTORI DAN FILE SENSITIF
# ========================================================================

# Lindungi file konfigurasi sensitif agar tidak bisa diunduh langsung via URL browser
<Files "config.php">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</Files>

# Lindungi cadangan database mentah SQL
<Files "database.sql">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</Files>

# Mencegah Directory Browsing index (Meningkatkan privasi file inventaris desa)
Options -Indexes
